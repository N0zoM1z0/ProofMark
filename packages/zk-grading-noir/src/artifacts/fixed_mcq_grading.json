{"noir_version":"1.0.0-beta.20+b4236c1957d0c26cb65d82adc9e5447b6ff1d629","hash":"1128313128593442740","abi":{"parameters":[{"name":"selected_choice_hashes","type":{"kind":"array","length":32,"type":{"kind":"field"}},"visibility":"private"},{"name":"correct_choice_hashes","type":{"kind":"array","length":32,"type":{"kind":"field"}},"visibility":"private"},{"name":"question_count","type":{"kind":"integer","sign":"unsigned","width":32},"visibility":"public"},{"name":"points_per_question","type":{"kind":"integer","sign":"unsigned","width":32},"visibility":"public"},{"name":"score","type":{"kind":"integer","sign":"unsigned","width":32},"visibility":"public"},{"name":"max_score","type":{"kind":"integer","sign":"unsigned","width":32},"visibility":"public"}],"return_type":null,"error_types":{"361444214588792908":{"error_kind":"string","string":"attempt to multiply with overflow"},"14990209321349310352":{"error_kind":"string","string":"attempt to add with overflow"}}},"bytecode":"","debug_symbols":"","file_map":{"50":{"source":"global MAX_QUESTIONS: u32 = 32;\n\nfn main(\n    selected_choice_hashes: [Field; 32],\n    correct_choice_hashes: [Field; 32],\n    question_count: pub u32,\n    points_per_question: pub u32,\n    score: pub u32,\n    max_score: pub u32,\n) {\n    let mut computed_score = 0;\n\n    for i in 0..MAX_QUESTIONS {\n        if i < question_count {\n            if selected_choice_hashes[i] == correct_choice_hashes[i] {\n                computed_score += points_per_question;\n            }\n        }\n    }\n\n    assert(computed_score == score);\n    assert(max_score == question_count * points_per_question);\n}\n","path":"/dsk/hdd/home/llmft/Web3/ZK/Project/ProofMark/circuits/fixed_mcq_grading/src/main.nr","function_locations":[{"start":232,"name":"main"}]}}}