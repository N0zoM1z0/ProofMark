{
  "name": "@proofmark/api",
  "private": true,
  "type": "module",
  "version": "0.1.0",
  "scripts": {
    "prebuild": "corepack pnpm --filter @proofmark/shared build",
    "dev": "tsx watch src/main.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/main.js",
    "lint": "eslint src --ext .ts",
    "pretest": "corepack pnpm --filter @proofmark/shared build",
    "test": "vitest run"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1034.0",
    "@nestjs/common": "^11.1.19",
    "@nestjs/core": "^11.1.19",
    "@nestjs/platform-express": "^11.1.19",
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "@proofmark/shared": "workspace:*",
    "@semaphore-protocol/group": "^4.14.2",
    "@semaphore-protocol/proof": "^4.14.2",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  }
}
